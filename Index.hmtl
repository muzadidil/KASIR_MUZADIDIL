<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Aemitra Inventory</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    .tab-content { display: none; animation: fadeUp 0.3s ease-out forwards; }
    .tab-active { display: block; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
    .pb-nav { padding-bottom: 120px; } 

    @media print {
      @page { margin: 0; }
      body { margin: 0; padding: 0; background: white !important; }
      body * { visibility: hidden; }
      nav { display: none !important; }
      #successModal { position: absolute; left: 0; top: 0; width: 100%; height: 100%; display: flex !important; justify-content: center !important; align-items: flex-start !important; padding-top: 20px; visibility: visible; }
      #areaPrintNota, #areaPrintNota * { visibility: visible; }
      #areaPrintNota { position: relative !important; width: 100%; max-width: 80mm; margin: 0 auto !important; box-shadow: none !important; border: 1px dashed #ccc !important; }
      .no-print { display: none !important; }
    }
  </style>
</head>
<body class="bg-gray-100 p-2 sm:p-5 pb-nav font-sans" onload="muatDropdown()">

  <div id="tab-ENTRY" class="tab-content tab-active w-full max-w-xl mx-auto mb-28">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="bg-blue-600 p-5 text-white flex justify-between items-center">
        <div><h1 class="text-xl font-black tracking-wider">KASIR INVENTORY</h1><p class="text-xs text-blue-200">Mode Multi-Barang</p></div>
        <i data-lucide="shopping-cart" class="w-8 h-8 opacity-80"></i>
      </div>

      <div class="p-5 bg-blue-50/50 border-b border-gray-200 space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-[11px] font-bold text-gray-500 uppercase">Kode Mutasi</label>
            <select id="kodeMutasi" onchange="updateHargaOtomatis()" class="w-full mt-1 bg-white border border-gray-300 rounded-lg px-3 py-2 outline-none focus:border-blue-500 font-semibold text-gray-800">
              <option value="OUT">OUT (Penjualan)</option>
              <option value="IN">IN (Pembelian)</option>
            </select>
          </div>
          <div>
            <label class="text-[11px] font-bold text-gray-500 uppercase">Customer / Supplier</label>
            <input list="listCustomer" id="customer" placeholder="Ketik/Pilih Cust..." class="w-full mt-1 bg-white border border-gray-300 rounded-lg px-3 py-2 outline-none focus:border-blue-500 font-semibold text-gray-800" autocomplete="off">
            <datalist id="listCustomer"></datalist>
          </div>
        </div>
      </div>

      <div class="p-5 space-y-4 border-b-4 border-gray-100">
        <div class="grid grid-cols-12 gap-3">
          <div class="col-span-12">
            <label class="text-[11px] font-bold text-gray-500 uppercase">Pilih / Ketik Barang</label>
            <input list="listBarang" id="namaBarang" oninput="updateHargaOtomatis()" placeholder="Ketik/Pilih Barang..." class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 font-semibold text-gray-800" autocomplete="off">
            <datalist id="listBarang"></datalist>
          </div>
          <div class="col-span-7">
            <label class="text-[11px] font-bold text-gray-500 uppercase">Harga Satuan</label>
            <input type="number" id="harga" placeholder="Rp" class="w-full mt-1 bg-gray-100 border border-gray-200 rounded-lg px-3 py-2.5 outline-none text-gray-600 font-bold" readonly>
          </div>
          <div class="col-span-5">
            <label class="text-[11px] font-bold text-gray-500 uppercase">Qty</label>
            <input type="number" id="jumlah" value="1" min="1" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2.5 outline-none focus:border-blue-500 font-semibold text-gray-800">
          </div>
        </div>
        
        <button type="button" onclick="tambahKeKeranjang()" class="w-full bg-blue-50 text-blue-600 border border-blue-200 hover:bg-blue-100 font-bold py-3 rounded-lg flex items-center justify-center gap-2 transition-all">
          <i data-lucide="plus-circle" class="w-5 h-5"></i> Tambah ke Struk
        </button>
      </div>

      <div class="p-5 bg-gray-50 min-h-[150px]">
        <h3 class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-3">Daftar Belanja</h3>
        <div id="wadahKeranjang" class="space-y-2">
          <p class="text-sm text-gray-400 text-center italic mt-5" id="teksKosong">Belum ada barang dipilih.</p>
        </div>
      </div>

      <div class="p-5 border-t border-gray-200 bg-white">
        <div class="flex justify-between items-end mb-5">
          <span class="text-sm font-bold text-gray-500 uppercase tracking-widest">Total Bayar</span>
          <span class="text-3xl font-black text-gray-900" id="totalBayar">Rp 0</span>
        </div>
        
        <button id="btnSimpan" onclick="simpanTransaksiFinal()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-black text-lg py-4 rounded-xl shadow-lg flex items-center justify-center gap-2 transition-all active:scale-95">
          <span id="btnText"><i data-lucide="check-square" class="w-6 h-6 inline-block align-middle mr-1"></i> SIMPAN TRANSAKSI</span>
          <div id="loading" class="hidden w-6 h-6 border-4 border-white border-t-transparent rounded-full animate-spin"></div>
        </button>
      </div>
    </div>
  </div>

  <div id="tab-MASTER" class="tab-content w-full max-w-xl mx-auto mb-28"><div class="bg-white rounded-2xl shadow-xl p-6 mt-4 border-t-4 border-blue-600"><div class="flex items-center gap-3 mb-6 border-b border-gray-100 pb-4"><div class="p-2 bg-blue-50 rounded-lg"><i data-lucide="database" class="w-5 h-5 text-blue-600"></i></div><div><h2 class="font-bold text-gray-800">Tambah Produk Baru</h2><p class="text-[10px] text-gray-500">Data masuk ke sheet MASTER</p></div></div><form id="formMaster" onsubmit="submitMaster(event)" class="space-y-4"><div class="grid grid-cols-2 gap-4"><div><label class="text-[11px] font-bold text-gray-500">Kode Barang</label><input type="text" id="mKode" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-blue-500" required></div><div><label class="text-[11px] font-bold text-gray-500">Nama Barang</label><input type="text" id="mNama" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-blue-500" required></div></div><div class="grid grid-cols-2 gap-4"><div><label class="text-[11px] font-bold text-gray-500">Kategori</label><select id="mKategori" onchange="cekDropdownBaru('mKategori', 'mKategoriBaru')" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-blue-500"><option value="Makanan">Makanan</option><option value="Minuman">Minuman</option><option value="NEW" class="font-bold text-blue-600">+ Tambah Baru...</option></select><input type="text" id="mKategoriBaru" placeholder="Ketik kategori..." class="hidden w-full mt-2 bg-blue-50 border border-blue-200 rounded-lg px-3 py-2 outline-none text-sm"></div><div><label class="text-[11px] font-bold text-gray-500">Unit / Satuan</label><select id="mUnit" onchange="cekDropdownBaru('mUnit', 'mUnitBaru')" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-blue-500"><option value="Pcs">Pcs</option><option value="Box">Box</option><option value="NEW" class="font-bold text-blue-600">+ Tambah Baru...</option></select><input type="text" id="mUnitBaru" placeholder="Ketik unit..." class="hidden w-full mt-2 bg-blue-50 border border-blue-200 rounded-lg px-3 py-2 outline-none text-sm"></div></div><div class="grid grid-cols-2 gap-4"><div><label class="text-[11px] font-bold text-gray-500">Harga Beli</label><input type="number" id="mBeli" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-blue-500" required></div><div><label class="text-[11px] font-bold text-gray-500">Harga Jual</label><input type="number" id="mJual" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-blue-500" required></div></div><button type="submit" id="btnSimpanMaster" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl mt-4 transition-colors">Simpan Barang</button></form></div></div>
  
  <div id="tab-CUST" class="tab-content w-full max-w-xl mx-auto mb-28"><div class="bg-white rounded-2xl shadow-xl p-6 mt-4 border-t-4 border-green-500"><div class="flex items-center gap-3 mb-6 border-b border-gray-100 pb-4"><div class="p-2 bg-green-50 rounded-lg"><i data-lucide="users" class="w-5 h-5 text-green-600"></i></div><div><h2 class="font-bold text-gray-800">Tambah Customer Baru</h2><p class="text-[10px] text-gray-500">Data masuk ke sheet CUST</p></div></div><form id="formCust" onsubmit="submitCust(event)" class="space-y-4"><div><label class="text-[11px] font-bold text-gray-500">Nama Pelanggan</label><input type="text" id="cNama" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-green-500" required></div><div><label class="text-[11px] font-bold text-gray-500">No. HP / WhatsApp</label><input type="text" id="cHp" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-green-500" required></div><div><label class="text-[11px] font-bold text-gray-500">Alamat</label><textarea id="cAlamat" rows="3" class="w-full mt-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-green-500" required></textarea></div><button type="submit" id="btnSimpanCust" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3 rounded-xl mt-4 transition-colors">Simpan Customer</button></form></div></div>
  
  <div id="tab-STOCK" class="tab-content w-full max-w-xl mx-auto mb-28"><div class="bg-white rounded-2xl shadow-xl p-4 mt-4 overflow-hidden border-t-4 border-orange-500"><div class="flex justify-between items-center mb-4 border-b border-gray-100 pb-3"><div class="flex items-center gap-3"><div class="p-2 bg-orange-50 rounded-lg"><i data-lucide="layers" class="w-5 h-5 text-orange-600"></i></div><h2 class="font-bold text-gray-800">Cek Stok</h2></div><button onclick="muatDataStok()" class="text-xs font-bold text-orange-500 bg-orange-50 px-3 py-1.5 rounded-full hover:bg-orange-100 transition-colors"><i data-lucide="refresh-cw" class="w-3 h-3 inline"></i> Refresh</button></div><div class="flex gap-2 mb-4"><div class="relative flex-1"><i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i><input type="text" id="cariStok" onkeyup="renderTabelStok()" placeholder="Cari barang..." class="w-full bg-gray-50 border border-gray-200 rounded-lg pl-9 pr-3 py-2.5 outline-none focus:border-orange-500 text-xs text-gray-700 font-medium transition-all"></div><select id="limitStok" onchange="renderTabelStok()" class="bg-gray-50 border border-gray-200 rounded-lg px-2 py-2.5 outline-none focus:border-orange-500 text-xs text-gray-700 font-bold w-24 transition-all"><option value="20" selected>20 Data</option><option value="50">50 Data</option><option value="100">100 Data</option><option value="ALL">Semua</option></select></div><div class="overflow-x-auto rounded-xl border border-gray-100"><table class="w-full text-left border-collapse whitespace-nowrap"><thead id="headerStok"><tr class="bg-orange-50/50 text-[10px] uppercase text-gray-500 tracking-wider border-b border-gray-200"><th class="p-3 font-bold">NAMA BARANG</th><th class="p-3 text-center font-bold">MASUK</th><th class="p-3 text-center font-bold">KELUAR</th><th class="p-3 text-center font-bold">RUSAK</th><th class="p-3 text-center font-bold">TERSEDIA</th></tr></thead><tbody id="tabelStok" class="text-xs text-gray-700 font-medium"><tr><td colspan="5" class="text-center p-6 italic text-gray-400">Klik refresh untuk memuat data stok...</td></tr></tbody></table></div><div class="mt-3 flex justify-end"><span id="infoStok" class="text-[10px] font-bold text-gray-400 uppercase tracking-widest bg-gray-50 px-2 py-1 rounded">Menampilkan 0 data</span></div></div></div>

  <div id="tab-MUTASI" class="tab-content w-full max-w-xl mx-auto mb-28">
    <div class="bg-white rounded-2xl shadow-xl p-4 mt-4 overflow-hidden border-t-4 border-purple-500">
      <div class="flex justify-between items-center mb-4 border-b border-gray-100 pb-3">
        <div class="flex items-center gap-3">
          <div class="p-2 bg-purple-50 rounded-lg"><i data-lucide="history" class="w-5 h-5 text-purple-600"></i></div>
          <h2 class="font-bold text-gray-800">Riwayat Transaksi</h2>
        </div>
        <button onclick="muatDataMutasi()" class="text-xs font-bold text-purple-500 bg-purple-50 px-3 py-1.5 rounded-full hover:bg-purple-100 transition-colors"><i data-lucide="refresh-cw" class="w-3 h-3 inline"></i> Refresh</button>
      </div>

      <div class="flex gap-2 mb-4">
        <div class="relative flex-1">
          <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
          <input type="text" id="cariMutasi" onkeyup="renderTabelMutasi()" placeholder="Cari nota, barang, cust..." class="w-full bg-gray-50 border border-gray-200 rounded-lg pl-9 pr-3 py-2.5 outline-none focus:border-purple-500 text-xs text-gray-700 font-medium transition-all">
        </div>
        <select id="limitMutasi" onchange="renderTabelMutasi()" class="bg-gray-50 border border-gray-200 rounded-lg px-2 py-2.5 outline-none focus:border-purple-500 text-xs text-gray-700 font-bold w-24 transition-all">
          <option value="20" selected>20 Data</option>
          <option value="50">50 Data</option>
          <option value="100">100 Data</option>
          <option value="ALL">Semua</option>
        </select>
      </div>

      <div class="overflow-x-auto rounded-xl border border-gray-100">
        <table class="w-full text-left border-collapse whitespace-nowrap">
          <thead>
            <tr class="bg-purple-50/50 text-[10px] uppercase text-gray-500 tracking-wider border-b border-gray-200">
              <th class="p-3 font-bold">Waktu & Nota</th>
              <th class="p-3 font-bold">Barang & Cust</th>
              <th class="p-3 text-center font-bold">Qty</th>
              <th class="p-3 text-center font-bold">Jenis</th>
            </tr>
          </thead>
          <tbody id="tabelMutasi" class="text-xs text-gray-700 font-medium">
            <tr><td colspan="4" class="text-center p-6 italic text-gray-400">Klik refresh untuk memuat riwayat...</td></tr>
          </tbody>
        </table>
      </div>
      <div class="mt-3 flex justify-end">
        <span id="infoMutasi" class="text-[10px] font-bold text-gray-400 uppercase tracking-widest bg-gray-50 px-2 py-1 rounded">Menampilkan 0 data</span>
      </div>
    </div>
  </div>

  <nav class="fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-md border-t border-gray-200 shadow-[0_-10px_20px_rgba(0,0,0,0.05)] z-50">
    <div class="flex justify-around items-center max-w-xl mx-auto p-2">
      <div id="btn-ENTRY" onclick="switchTab('ENTRY')" class="nav-item text-blue-600 font-bold flex flex-col items-center justify-center w-full py-2 cursor-pointer transition-all relative"><div class="nav-indicator absolute top-[-8px] w-6 h-1 bg-blue-600 rounded-b-lg"></div><i data-lucide="shopping-cart" class="w-5 h-5 mb-1"></i><span class="text-[9px] uppercase tracking-wider">Kasir</span></div>
      <div id="btn-MASTER" onclick="switchTab('MASTER')" class="nav-item text-gray-400 flex flex-col items-center justify-center w-full py-2 cursor-pointer transition-all relative hover:text-blue-400"><div class="nav-indicator absolute top-[-8px] w-6 h-1 bg-blue-600 rounded-b-lg hidden"></div><i data-lucide="database" class="w-5 h-5 mb-1"></i><span class="text-[9px] uppercase tracking-wider">Master</span></div>
      <div id="btn-CUST" onclick="switchTab('CUST')" class="nav-item text-gray-400 flex flex-col items-center justify-center w-full py-2 cursor-pointer transition-all relative hover:text-green-500"><div class="nav-indicator absolute top-[-8px] w-6 h-1 bg-green-500 rounded-b-lg hidden"></div><i data-lucide="users" class="w-5 h-5 mb-1"></i><span class="text-[9px] uppercase tracking-wider">Cust</span></div>
      <div id="btn-STOCK" onclick="switchTab('STOCK')" class="nav-item text-gray-400 flex flex-col items-center justify-center w-full py-2 cursor-pointer transition-all relative hover:text-orange-500"><div class="nav-indicator absolute top-[-8px] w-6 h-1 bg-orange-500 rounded-b-lg hidden"></div><i data-lucide="layers" class="w-5 h-5 mb-1"></i><span class="text-[9px] uppercase tracking-wider">Stock</span></div>
      <div id="btn-MUTASI" onclick="switchTab('MUTASI')" class="nav-item text-gray-400 flex flex-col items-center justify-center w-full py-2 cursor-pointer transition-all relative hover:text-purple-500"><div class="nav-indicator absolute top-[-8px] w-6 h-1 bg-purple-500 rounded-b-lg hidden"></div><i data-lucide="history" class="w-5 h-5 mb-1"></i><span class="text-[9px] uppercase tracking-wider">Riwayat</span></div>
    </div>
  </nav>

  <div id="successModal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm no-print"></div>
    <div id="areaPrintNota" class="relative bg-white rounded-3xl w-full max-w-sm text-center shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
      <div class="bg-blue-50/50 border-b border-gray-100 p-5 shrink-0">
        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-2 no-print"><i data-lucide="check-circle" class="text-green-600 w-6 h-6"></i></div>
        <h3 class="text-lg font-extrabold text-gray-800">AEMITRA INVENTORY</h3>
        <p class="text-[10px] text-gray-500 uppercase tracking-widest font-semibold mt-1">Struk Transaksi</p>
      </div>
      <div class="p-5 text-left bg-white overflow-y-auto shrink">
        <div class="flex justify-between items-center border-b border-dashed border-gray-200 pb-2 mb-2"><span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">No. Nota</span><span id="strukNota" class="text-sm font-black text-blue-600"></span></div>
        <div class="flex justify-between items-center border-b border-dashed border-gray-200 pb-2 mb-2"><span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Tanggal</span><span id="strukTanggal" class="text-xs font-semibold text-gray-700"></span></div>
        <div class="flex justify-between items-center border-b border-dashed border-gray-200 pb-2 mb-2"><span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Customer</span><span id="strukCustomer" class="text-xs font-semibold text-gray-700"></span></div>
        <div class="flex justify-between items-center border-b border-dashed border-gray-200 pb-2 mb-4"><span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Mutasi</span><span id="strukMutasi" class="px-2 py-0.5 rounded text-[10px] font-bold text-white tracking-widest"></span></div>
        <div class="border border-gray-100 rounded-xl p-3 bg-gray-50/50">
          <h4 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest border-b border-gray-200 pb-2 mb-2">Daftar Item</h4>
          <div id="strukDaftarBarang" class="space-y-2 mb-3"></div>
          <div class="border-t border-gray-200 pt-3 flex justify-between items-center"><span class="text-xs font-bold text-gray-600 uppercase tracking-wider">Total</span><span id="strukTotal" class="text-base font-black text-gray-900"></span></div>
        </div>
      </div>
      <div class="p-5 bg-gray-50 grid grid-cols-2 gap-3 shrink-0 no-print">
        <button onclick="cetakNota()" class="w-full py-3 bg-white border border-gray-200 hover:bg-gray-100 text-gray-700 font-bold rounded-xl transition-all text-sm flex items-center justify-center gap-2"><i data-lucide="printer" class="w-4 h-4"></i> Cetak</button>
        <button onclick="closeModal()" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-all shadow-md text-sm">Tutup</button>
      </div>
    </div>
  </div>

  <script>
    lucide.createIcons();

    let keranjang = []; 
    let masterDataBarang = {}; 
    let dataStokGlobal = []; 
    let dataMutasiGlobal = []; // Variabel untuk data riwayat mutasi

    function formatRp(angka) { return angka.toString().replace(/\B(?=(\d{3})+(?!\d))/g, "."); }

    // --- FUNGSI TAB 1: KASIR ---
    function muatDropdown() {
      google.script.run.withSuccessHandler(function(data) {
        masterDataBarang = data.barangDict; 
        
        let selBarang = document.getElementById('listBarang');
        selBarang.innerHTML = ''; 
        Object.keys(masterDataBarang).forEach(b => {
          selBarang.innerHTML += `<option value="${b}">`;
        });

        let selCust = document.getElementById('listCustomer');
        selCust.innerHTML = '';
        data.customer.forEach(c => selCust.innerHTML += `<option value="${c}">`);
      }).getDropdownData();
    }

    function updateHargaOtomatis() {
      let nama = document.getElementById('namaBarang').value;
      let mutasi = document.getElementById('kodeMutasi').value; 
      let inputHarga = document.getElementById('harga');

      if(nama !== "" && masterDataBarang[nama]) {
        if(mutasi === "OUT") inputHarga.value = masterDataBarang[nama].jual; 
        else if (mutasi === "IN") inputHarga.value = masterDataBarang[nama].beli; 
      } else {
        inputHarga.value = ""; 
      }
    }

    function tambahKeKeranjang() {
      let nama = document.getElementById('namaBarang').value;
      let qty = parseInt(document.getElementById('jumlah').value);
      let harga = parseInt(document.getElementById('harga').value) || 0; 

      if(nama === "") { alert("Silakan pilih barang terlebih dahulu!"); return; }
      if(isNaN(qty) || qty < 1) { alert("Jumlah tidak valid!"); return; }

      keranjang.push({ namaBarang: nama, jumlah: qty, harga: harga, subtotal: harga * qty });

      document.getElementById('namaBarang').value = "";
      document.getElementById('jumlah').value = "1";
      document.getElementById('harga').value = "";
      renderKeranjang();
    }

    function renderKeranjang() {
      let wadah = document.getElementById('wadahKeranjang');
      let totalElemen = document.getElementById('totalBayar');
      wadah.innerHTML = ""; 
      let grandTotal = 0;

      if(keranjang.length === 0) {
        wadah.innerHTML = `<p class="text-sm text-gray-400 text-center italic mt-5">Belum ada barang dipilih.</p>`;
        totalElemen.innerText = "Rp 0";
        return;
      }

      keranjang.forEach((item, index) => {
        grandTotal += item.subtotal;
        wadah.innerHTML += `
          <div class="flex justify-between items-center bg-white p-3 rounded-lg border border-gray-100 shadow-sm">
            <div>
              <p class="font-bold text-gray-800 text-sm">${item.namaBarang}</p>
              <p class="text-[11px] font-semibold text-gray-500">${item.jumlah} Pcs x Rp ${formatRp(item.harga)}</p>
            </div>
            <div class="flex items-center gap-3">
              <span class="font-black text-blue-600 text-sm">Rp ${formatRp(item.subtotal)}</span>
              <button onclick="hapusItem(${index})" class="text-red-400 hover:text-red-600"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
            </div>
          </div>
        `;
      });
      lucide.createIcons();
      totalElemen.innerText = "Rp " + formatRp(grandTotal);
    }

    function hapusItem(index) { keranjang.splice(index, 1); renderKeranjang(); }

    function simpanTransaksiFinal() {
      let customer = document.getElementById('customer').value;
      let kodeMutasi = document.getElementById('kodeMutasi').value;

      if(customer === "") { alert("Customer wajib diisi!"); return; }
      if(keranjang.length === 0) { alert("Keranjang masih kosong!"); return; }

      let payload = { customer: customer, kodeMutasi: kodeMutasi, dataKeranjang: keranjang };

      document.getElementById('btnText').classList.add('hidden');
      document.getElementById('loading').classList.remove('hidden');
      document.getElementById('btnSimpan').disabled = true;

      google.script.run
        .withSuccessHandler((pesan) => {
          let resNota = pesan.split("Nota: ")[1] || "SH-XXXXX";
          
          let dt = new Date();
          let bulan = ["Jan","Feb","Mar","Apr","Mei","Jun","Jul","Ags","Sep","Okt","Nov","Des"];
          let tglNota = dt.getDate() + "-" + bulan[dt.getMonth()] + "-" + dt.getFullYear();

          document.getElementById('strukNota').innerText = resNota;
          document.getElementById('strukTanggal').innerText = tglNota;
          document.getElementById('strukCustomer').innerText = payload.customer;

          let sm = document.getElementById('strukMutasi');
          if(payload.kodeMutasi === "OUT") { sm.innerText = "OUT (Penjualan)"; sm.className = "bg-blue-500 px-2 py-0.5 rounded text-[10px] font-bold text-white tracking-widest"; }
          else { sm.innerText = "IN (Pembelian)"; sm.className = "bg-green-500 px-2 py-0.5 rounded text-[10px] font-bold text-white tracking-widest"; }

          let containerDaftar = document.getElementById('strukDaftarBarang');
          containerDaftar.innerHTML = "";
          let strukGrandTotal = 0;
          
          payload.dataKeranjang.forEach(item => {
            strukGrandTotal += item.subtotal;
            containerDaftar.innerHTML += `<div class="flex justify-between items-center text-[11px] font-semibold text-gray-700 py-1 border-b border-dashed border-gray-100 last:border-0"><span class="truncate w-3/5">${item.namaBarang}</span><span class="w-1/5 text-center">${item.jumlah}x</span><span class="w-1/5 text-right font-bold text-gray-900">${formatRp(item.subtotal)}</span></div>`;
          });
          document.getElementById('strukTotal').innerText = "Rp " + formatRp(strukGrandTotal);

          document.getElementById('successModal').classList.remove('hidden');
          document.getElementById('successModal').classList.add('flex');
          if (navigator.vibrate) navigator.vibrate([50, 30, 50]);

          keranjang = []; renderKeranjang();
          document.getElementById('customer').value = "";
          document.getElementById('btnText').classList.remove('hidden');
          document.getElementById('loading').classList.add('hidden');
          document.getElementById('btnSimpan').disabled = false;
          
          // Refresh background data jika ditambahkan
          if(dataStokGlobal.length > 0) muatDataStok();
          if(dataMutasiGlobal.length > 0) muatDataMutasi();
        })
        .withFailureHandler((err) => {
          alert("Gagal: " + err.message);
          document.getElementById('btnText').classList.remove('hidden');
          document.getElementById('loading').classList.add('hidden');
          document.getElementById('btnSimpan').disabled = false;
        })
        .simpanDataEntry(payload); 
    }

    function cetakNota() {
      const judulAsli = document.title;
      document.title = "Struk_Aemitra"; 
      window.print();
      setTimeout(() => { document.title = judulAsli; }, 100);
    }
    function closeModal() { document.getElementById('successModal').classList.add('hidden'); document.getElementById('successModal').classList.remove('flex'); }

    // --- FUNGSI TAB 2 & 3: FORM MASTER DAN CUSTOMER ---
    function cekDropdownBaru(idSelect, idInputBox) {
      let sel = document.getElementById(idSelect).value;
      let box = document.getElementById(idInputBox);
      if (sel === "NEW") { box.classList.remove('hidden'); box.required = true; } 
      else { box.classList.add('hidden'); box.required = false; }
    }

    function submitCust(e) {
      e.preventDefault();
      let btn = document.getElementById('btnSimpanCust');
      btn.innerText = "Menyimpan..."; btn.disabled = true;
      let payload = { nama: document.getElementById('cNama').value, hp: document.getElementById('cHp').value, alamat: document.getElementById('cAlamat').value };
      google.script.run.withSuccessHandler((res) => {
        alert(res); document.getElementById('formCust').reset();
        btn.innerText = "Simpan Customer"; btn.disabled = false;
        muatDropdown(); 
      }).simpanCustomerBaru(payload);
    }

    function submitMaster(e) {
      e.preventDefault();
      let btn = document.getElementById('btnSimpanMaster');
      btn.innerText = "Menyimpan..."; btn.disabled = true;

      let valKategori = document.getElementById('mKategori').value;
      if(valKategori === "NEW") valKategori = document.getElementById('mKategoriBaru').value;
      
      let valUnit = document.getElementById('mUnit').value;
      if(valUnit === "NEW") valUnit = document.getElementById('mUnitBaru').value;

      let payload = {
        kode: document.getElementById('mKode').value, nama: document.getElementById('mNama').value,
        kategori: valKategori, unit: valUnit, hargaBeli: document.getElementById('mBeli').value, hargaJual: document.getElementById('mJual').value
      };

      google.script.run.withSuccessHandler((res) => {
        alert(res); document.getElementById('formMaster').reset();
        document.getElementById('mKategoriBaru').classList.add('hidden'); document.getElementById('mUnitBaru').classList.add('hidden');
        btn.innerText = "Simpan Barang"; btn.disabled = false;
        muatDropdown(); 
      }).simpanBarangBaru(payload);
    }

    // --- FUNGSI TAB 4: STOCK ---
    function muatDataStok() {
      let tbody = document.getElementById('tabelStok');
      let info = document.getElementById('infoStok');
      tbody.innerHTML = `<tr><td colspan="5" class="text-center p-8"><div class="w-6 h-6 border-2 border-orange-500 border-t-transparent rounded-full animate-spin mx-auto mb-2"></div><p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold">Menarik Data...</p></td></tr>`;
      info.innerText = "MEMUAT...";

      google.script.run.withSuccessHandler((response) => {
        dataStokGlobal = response; 
        renderTabelStok();     
      }).getStokData();
    }

    function renderTabelStok() {
      let tbody = document.getElementById('tabelStok');
      let info = document.getElementById('infoStok');
      
      let kataKunci = document.getElementById('cariStok').value.toLowerCase();
      let limit = document.getElementById('limitStok').value;
      
      let dataTersaring = dataStokGlobal.filter(row => row.kolomB.toString().toLowerCase().includes(kataKunci));
      let jumlahDataDitemukan = dataTersaring.length;

      if (limit !== "ALL") dataTersaring = dataTersaring.slice(0, parseInt(limit));

      tbody.innerHTML = "";
      if(dataTersaring.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center p-6 italic text-gray-400 font-semibold">Data tidak ditemukan.</td></tr>`;
        info.innerText = `Menampilkan 0 dari 0 data`;
        return;
      }

      dataTersaring.forEach(row => {
        tbody.innerHTML += `
          <tr class="border-b border-gray-50 hover:bg-orange-50/50 transition-colors">
            <td class="p-3 font-bold text-gray-800">${row.kolomB}</td>
            <td class="p-3 text-center text-gray-500">${row.kolomF}</td>
            <td class="p-3 text-center text-gray-500">${row.kolomG}</td>
            <td class="p-3 text-center text-gray-500">${row.kolomH}</td>
            <td class="p-3 text-center font-black text-orange-600">${row.kolomI}</td>
          </tr>`;
      });
      info.innerText = `Menampilkan ${dataTersaring.length} dari ${jumlahDataDitemukan} data`;
      lucide.createIcons();
    }

    // --- FUNGSI TAB 5: RIWAYAT / MUTASI (BARU) ---
    function muatDataMutasi() {
      let tbody = document.getElementById('tabelMutasi');
      let info = document.getElementById('infoMutasi');
      tbody.innerHTML = `<tr><td colspan="4" class="text-center p-8"><div class="w-6 h-6 border-2 border-purple-500 border-t-transparent rounded-full animate-spin mx-auto mb-2"></div><p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold">Menarik Riwayat...</p></td></tr>`;
      info.innerText = "MEMUAT...";

      google.script.run.withSuccessHandler((response) => {
        dataMutasiGlobal = response; 
        renderTabelMutasi();     
      }).getMutasiData();
    }

    function renderTabelMutasi() {
      let tbody = document.getElementById('tabelMutasi');
      let info = document.getElementById('infoMutasi');
      
      let kataKunci = document.getElementById('cariMutasi').value.toLowerCase();
      let limit = document.getElementById('limitMutasi').value;
      
      // Pencarian bisa dari nama nota, barang, atau customer
      let dataTersaring = dataMutasiGlobal.filter(row => {
        let gabung = (row.nota + " " + row.barang + " " + row.customer).toLowerCase();
        return gabung.includes(kataKunci);
      });
      
      let jumlahDataDitemukan = dataTersaring.length;

      if (limit !== "ALL") dataTersaring = dataTersaring.slice(0, parseInt(limit));

      tbody.innerHTML = "";
      if(dataTersaring.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" class="text-center p-6 italic text-gray-400 font-semibold">Riwayat tidak ditemukan.</td></tr>`;
        info.innerText = `Menampilkan 0 dari 0 data`;
        return;
      }

      dataTersaring.forEach(row => {
        let badgeClass = row.jenis === "IN" ? "bg-green-100 text-green-700" : "bg-blue-100 text-blue-700";
        
        tbody.innerHTML += `
          <tr class="border-b border-gray-50 hover:bg-purple-50/50 transition-colors">
            <td class="p-3">
              <p class="font-bold text-gray-800">${row.nota}</p>
              <p class="text-[10px] text-gray-500">${row.tanggal} ${row.waktu}</p>
            </td>
            <td class="p-3">
              <p class="font-bold text-gray-800 truncate max-w-[120px]">${row.barang}</p>
              <p class="text-[10px] text-gray-500 truncate max-w-[120px]"><i data-lucide="user" class="w-3 h-3 inline"></i> ${row.customer}</p>
            </td>
            <td class="p-3 text-center font-black text-gray-700">${row.qty}</td>
            <td class="p-3 text-center">
              <span class="px-2 py-1 rounded text-[10px] font-bold tracking-widest ${badgeClass}">${row.jenis}</span>
            </td>
          </tr>`;
      });
      info.innerText = `Menampilkan ${dataTersaring.length} dari ${jumlahDataDitemukan} data`;
      lucide.createIcons();
    }

    // --- NAVIGASI ---
    function switchTab(tabId) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('tab-active'));
      document.querySelectorAll('.nav-item').forEach(el => {
        el.classList.remove('text-blue-600', 'text-green-500', 'text-orange-500', 'text-purple-500', 'font-bold');
        el.classList.add('text-gray-400');
        el.querySelector('.nav-indicator').classList.add('hidden');
      });
      document.getElementById('tab-' + tabId).classList.add('tab-active');
      const activeBtn = document.getElementById('btn-' + tabId);
      activeBtn.classList.remove('text-gray-400');
      activeBtn.classList.add('font-bold');
      
      if (tabId === 'ENTRY') activeBtn.classList.add('text-blue-600');
      if (tabId === 'MASTER') activeBtn.classList.add('text-blue-600');
      if (tabId === 'CUST') activeBtn.classList.add('text-green-500');
      if (tabId === 'STOCK') { 
        activeBtn.classList.add('text-orange-500'); 
        if(dataStokGlobal.length === 0) muatDataStok(); 
      }
      if (tabId === 'MUTASI') { 
        activeBtn.classList.add('text-purple-500'); 
        if(dataMutasiGlobal.length === 0) muatDataMutasi(); 
      }

      activeBtn.querySelector('.nav-indicator').classList.remove('hidden');
      lucide.createIcons();
    }
  </script>
</body>
</html>
